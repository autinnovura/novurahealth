# NovuraHealth — environment variable template
#
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# `.env.local` is gitignored; this file (`.env.example`) is committed as a reference.
#
# Local-only quickstart: you can omit RESEND_API_KEY and the VAPID keys if you don't
# need to test welcome emails or push notifications. Everything else is required.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Public anon URL and key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER-SIDE ONLY. Bypasses RLS. Never import in a client component.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Powers the AI coach, plan generation, and import parsing.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Used for sliding-window rate limiting and dedup. REST API must be enabled.
UPSTASH_REDIS_REST_URL=https://your-region-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ─── Cron auth ────────────────────────────────────────────────────────────────
# Protects every /api/cron/* endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate-a-long-random-string

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Welcome emails and weekly digest. Optional for local dev if you skip those flows.
RESEND_API_KEY=re_your_resend_api_key

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate a fresh keypair with:
#   npx web-push generate-vapid-keys
# Public key is exposed to the browser; private key stays server-side.
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
